{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile-java",
            "type": "shell",
            "command": "javac",
            "args": [
                "-cp",
                ".;lib/mysql-connector-j-9.4.0.jar",
                "*.java"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": "$javac",
            "detail": "Compile all Java files with MySQL connector"
        },
        {
            "label": "run-trip-planner",
            "type": "shell",
            "command": "java",
            "args": [
                "-cp",
                ".;lib/mysql-connector-j-9.4.0.jar",
                "TripPlannerApp"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "dependsOn": "compile-java",
            "detail": "Run the Trip Planner application"
        },
        {
            "label": "clean-class-files",
            "type": "shell",
            "command": "del",
            "args": [
                "*.class"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "detail": "Clean up compiled .class files"
        }
    ]
}

